# Dockerfile for Fabric Framework by Daniel Miessler
# Simple single-stage build with everything included

FROM golang:1.24-alpine

# Install all required packages and tools
RUN apk add --no-cache \
    git \
    ca-certificates \
    bash \
    curl \
    wget \
    vim \
    nano \
    jq \
    xclip \
    && rm -rf /var/cache/apk/*

# Install Fabric
RUN go install github.com/danielmiessler/fabric/cmd/fabric@latest

# Create a user for running fabric
RUN adduser -D -s /bin/bash fabricuser

# Switch to the fabricuser
USER fabricuser
WORKDIR /home/fabricuser

# Create necessary directories
RUN mkdir -p /home/fabricuser/.config/fabric

# Set environment variables
ENV PATH="/go/bin:$PATH"
ENV FABRIC_CONFIG_DIR="/home/fabricuser/.config/fabric"

# Create helpful aliases and setup info
RUN echo 'alias pbpaste="xclip -selection clipboard -o"' >> /home/fabricuser/.bashrc && \
    echo 'alias pbcopy="xclip -selection clipboard"' >> /home/fabricuser/.bashrc && \
    echo '' >> /home/fabricuser/.bashrc && \
    echo '# Fabric Framework is ready!' >> /home/fabricuser/.bashrc && \
    echo '# First time setup: fabric --setup' >> /home/fabricuser/.bashrc && \
    echo '# List patterns: fabric --listpatterns' >> /home/fabricuser/.bashrc && \
    echo '# Usage: echo "text" | fabric --pattern summarize' >> /home/fabricuser/.bashrc && \
    echo '# Help: fabric -h' >> /home/fabricuser/.bashrc

# Default command
CMD ["/bin/bash"]